# Workspace-specific values used by:
#   - databricks.yml (bundle deploy)
#   - apps/rules-editor/app.yaml (app deployment)
#   - apps/rules-editor/server/services/databricks.py (local app dev)
#   - notebook job triggers from the rules-editor app
#
# Copy to .env.local and fill in your real values:
#   cp .env.local.example .env.local
#
# Then source before any deploy/run:
#   set -a; source .env.local; set +a
#
# .env.local is gitignored — your real values never travel to the public repo.

# Databricks CLI profile (must exist in ~/.databrickscfg)
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Unity Catalog target — where rules, tables, and the shaded JAR live
UC_CATALOG=main
UC_SCHEMA=irs_rrp
UC_VOLUME=dmn_rules

# Workspace IDs the rules-editor app needs
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CLUSTER_ID=
SCORING_JOB_ID=
SCORING_NOTEBOOK_PATH=/Workspace/Shared/fraud_rules_engine/04_batch_scoring
