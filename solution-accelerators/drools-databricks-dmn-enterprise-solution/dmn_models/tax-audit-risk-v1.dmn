<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="tax-audit-risk-definitions" name="Tax Audit Risk" namespace="https://example.com/dmn/tax-audit-risk">
  <inputData id="input_agi" name="agi"><variable id="var_agi" name="agi" typeRef="number"/></inputData>
  <inputData id="input_total_deductions" name="total_deductions"><variable id="var_total_deductions" name="total_deductions" typeRef="number"/></inputData>
  <inputData id="input_foreign_income" name="foreign_income"><variable id="var_foreign_income" name="foreign_income" typeRef="number"/></inputData>
  <decision id="decision_high_deduction_risk" name="High_Deduction_Risk"><variable id="var_high_deduction_risk" name="High_Deduction_Risk" typeRef="number"/><informationRequirement><requiredInput href="#input_agi"/></informationRequirement><informationRequirement><requiredInput href="#input_total_deductions"/></informationRequirement><literalExpression id="expr_high_deduction_risk" typeRef="number"><text>if agi &gt; 0 and total_deductions &gt; agi * 0.5 then 40 else 0</text></literalExpression></decision>
  <decision id="decision_foreign_income_risk" name="foreign_income_risk"><variable id="var_foreign_income_risk" name="foreign_income_risk" typeRef="number"/><informationRequirement><requiredInput href="#input_foreign_income"/></informationRequirement><literalExpression id="expr_foreign_income_risk" typeRef="number"><text>if foreign_income &gt; 10000 then 35 else 0</text></literalExpression></decision>
  <decision id="decision_low_income_high_spend" name="low_income_high_spend"><variable id="var_low_income_high_spend" name="low_income_high_spend" typeRef="number"/><informationRequirement><requiredInput href="#input_agi"/></informationRequirement><informationRequirement><requiredInput href="#input_total_deductions"/></informationRequirement><literalExpression id="expr_low_income_high_spend" typeRef="number"><text>if agi &lt; 30000 and total_deductions &gt; 5000 then 25 else 0</text></literalExpression></decision>
  <decision id="decision_risk_score" name="Risk_score"><variable id="var_risk_score" name="Risk_score" typeRef="number"/><informationRequirement><requiredDecision href="#decision_high_deduction_risk"/></informationRequirement><informationRequirement><requiredDecision href="#decision_foreign_income_risk"/></informationRequirement><informationRequirement><requiredDecision href="#decision_low_income_high_spend"/></informationRequirement><literalExpression id="expr_risk_score" typeRef="number"><text>sum([High_Deduction_Risk, foreign_income_risk, low_income_high_spend])</text></literalExpression></decision>
  <decision id="decision_audit_action" name="Audit_action"><variable id="var_audit_action" name="Audit_action" typeRef="string"/><informationRequirement><requiredDecision href="#decision_risk_score"/></informationRequirement><decisionTable id="audit_action_table" hitPolicy="FIRST"><input id="aa_score"><inputExpression id="aa_score_expr" typeRef="number"><text>Risk_score</text></inputExpression></input><output id="aa_output" name="Audit_action" typeRef="string"/><rule id="flag"><inputEntry id="flag_score"><text>&gt;= 70</text></inputEntry><outputEntry id="flag_out"><text>"FLAG"</text></outputEntry></rule><rule id="review"><inputEntry id="review_score"><text>&gt;= 35</text></inputEntry><outputEntry id="review_out"><text>"REVIEW"</text></outputEntry></rule><rule id="pass"><inputEntry id="pass_score"><text>-</text></inputEntry><outputEntry id="pass_out"><text>"PASS"</text></outputEntry></rule></decisionTable></decision>
</definitions>
